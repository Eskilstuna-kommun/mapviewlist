    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "mini-css-extract-plugin": "^2.10.2",
    "sass": "^1.99.0",
    "postcss-loader": "^7.3.3",
    "sass-loader":"16.0.7",
    "style-loader": "^4.0.0",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
