{
  "name": "mapviewlist",
  "version": "1.0.0",
  "description": "",
  "main": "mapviewlist.js",
  "scripts": {
    "start": "npm-run-all --parallel watch-js watch-sass",
    "watch-js": "webpack-dev-server --config ./tasks/webpack.dev.js --mode development",
    "watch-sass": "sass -w scss/mapviewlist.scss ../origo/plugins/mapviewlist.css",
    "build": "webpack --config ./tasks/webpack.prod.js && npm run build-sass",
    "build-dev": "webpack --config ./tasks/webpack.dev.js",
    "build-sass": "sass scss/mapviewlist.scss build/css/mapviewlist.css",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
